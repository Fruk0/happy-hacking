      "boundElements": [],
      "updated": 1776903208488,
      "link": null,
      "locked": false,
      "text": "subfinder -d ohgiftcard.com -silent | tee subfinder_oh.txt\nassetfinder --subs-only ohgiftcard.com | grep -E '(^|\\.)ohgiftcard\\.com$' | tee assetfinder_oh.txt\ncat subfinder_oh.txt assetfinder_oh.txt | sort -u | tee all_ohgiftcard.txt\ndnsx -l all_ohgiftcard.txt -silent | awk '{print $1}' | tee resolved_ohgiftcard.txt\nhttpx -l resolved_ohgiftcard.txt -sc -title -tech-detect -location -ip -silent | tee httpx_ohgiftcard.txt",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "IK_g0kXsfy5b30n15Warn",
      "originalText": "subfinder -d ohgiftcard.com -silent | tee subfinder_oh.txt\nassetfinder --subs-only ohgiftcard.com | grep -E '(^|\\.)ohgiftcard\\.com$' | tee assetfinder_oh.txt\ncat subfinder_oh.txt assetfinder_oh.txt | sort -u | tee all_ohgiftcard.txt\ndnsx -l all_ohgiftcard.txt -silent | awk '{print $1}' | tee resolved_ohgiftcard.txt\nhttpx -l resolved_ohgiftcard.txt -sc -title -tech-detect -location -ip -silent | tee httpx_ohgiftcard.txt",
      "autoResize": true,
      "lineHeight": 1.25
    },
