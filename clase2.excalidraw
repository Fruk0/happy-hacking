    {
      "id": "5ya_SawqWv9ytN87y0f7t",
      "type": "text",
      "x": 2396.7169927558584,
      "y": -110.99287236836801,
      "width": 378.39947509765625,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fcc2d7",
      "fillStyle": "solid",
      "strokeWidth": 2,
