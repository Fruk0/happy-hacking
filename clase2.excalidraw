    {
      "id": "C9EFZqfPLhgSBbczaAwzE",
      "type": "text",
      "x": 1706.698063297238,
      "y": 1048.4076927189794,
      "width": 483.99932861328125,
      "height": 520,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fcc2d7",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0M",
      "roundness": null,
      "seed": 1553076052,
      "version": 1450,
      "versionNonce": 1773768300,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776882696711,
      "link": null,
      "locked": false,
      "text": "CENSYS DORKS\n\n1) Buscar hosts por nombre DNS\n\nhost.dns.names: \"tesla.com\"\nhost.dns.names: \"*.tesla.com\"\n\n2) Filtrar por puerto expuesto\n\nhost.dns.names: \"tesla.com\" AND host.services.port: 443\nhost.dns.names: \"tesla.com\" AND host.services.port: 80\nhost.services.port: 22\nhost.services.port: 3389\n\n3) Buscar por título o tecnología web\n\nhostname:\"tesla.com\" http.title:\"Tesla\"\nhostname:\"tesla.com\" nginx\nhostname:\"tesla.com\" apache\nhostname:\"tesla.com\" \"cloudflare\"\n\n4) Buscar por certificados TLS\n\nssl.cert.subject.cn:\"tesla.com\"\nssl:\"*.tesla.com\"\nssl:\"tesla.com\"",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "yRu--e-FiNZI9UjjipRW-",
      "originalText": "CENSYS DORKS\n\n1) Buscar hosts por nombre DNS\n\nhost.dns.names: \"tesla.com\"\nhost.dns.names: \"*.tesla.com\"\n\n2) Filtrar por puerto expuesto\n\nhost.dns.names: \"tesla.com\" AND host.services.port: 443\nhost.dns.names: \"tesla.com\" AND host.services.port: 80\nhost.services.port: 22\nhost.services.port: 3389\n\n3) Buscar por título o tecnología web\n\nhostname:\"tesla.com\" http.title:\"Tesla\"\nhostname:\"tesla.com\" nginx\nhostname:\"tesla.com\" apache\nhostname:\"tesla.com\" \"cloudflare\"\n\n4) Buscar por certificados TLS\n\nssl.cert.subject.cn:\"tesla.com\"\nssl:\"*.tesla.com\"\nssl:\"tesla.com\"",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "f76Bdi3phw8VaNTGWiip6",
      "type": "rectangle",
      "x": 2372.189455047247,
      "y": 970.3127901923451,
      "width": 545.7269466095437,
      "height": 870,
      "angle": 0,
      "strokeColor": "#1e1e1e",
