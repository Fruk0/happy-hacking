      "versionNonce": 962370156,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776901019021,
      "link": null,
      "locked": false,
      "text": "Comandos\n\ndig MX target.com +short\ndig NS target.com +short\ndig TXT target.com +short\nhost -t MX mercadolibre.com \n",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "OOqvxTTpOB_qpORSc-Ym2",
      "originalText": "Comandos\n\ndig MX target.com +short\ndig NS target.com +short\ndig TXT target.com +short\nhost -t MX mercadolibre.com \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "3gmCfJUhvQQz8IY1_9UAT",
      "type": "text",
      "x": 1631.6914804558241,
      "y": -622.5026891765611,
      "width": 864,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f8f1ee",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "as",
      "roundness": null,
      "seed": 1308075476,
      "version": 198,
      "versionNonce": 359138412,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776869895491,
      "link": null,
      "locked": false,
      "text": "SUPERFICIE DE ATAQUE — QUÉ ESTAMOS MAPEANDO\n══════════════════════════════════════════════════════\n\n  nexus-financial.com\n         │\n         ├── api.nexus-financial.com         ← API expuesta\n         ├── dev.nexus-financial.com         ← entorno de desarrollo\n         ├── admin.nexus-financial.com       ← panel de administración\n         ├── vpn.nexus-financial.com         ← acceso remoto\n         ├── mail.nexus-financial.com        ← servidor de correo\n         └── staging.nexus-financial.com     ← versión de prueba\n\n  Cada subdominio = una puerta potencial\n  Cada servicio expuesto = una superficie de ataque\n  Cada empleado con email público = un vector de phishing",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SUPERFICIE DE ATAQUE — QUÉ ESTAMOS MAPEANDO\n══════════════════════════════════════════════════════\n\n  nexus-financial.com\n         │\n         ├── api.nexus-financial.com         ← API expuesta\n         ├── dev.nexus-financial.com         ← entorno de desarrollo\n         ├── admin.nexus-financial.com       ← panel de administración\n         ├── vpn.nexus-financial.com         ← acceso remoto\n         ├── mail.nexus-financial.com        ← servidor de correo\n         └── staging.nexus-financial.com     ← versión de prueba\n\n  Cada subdominio = una puerta potencial\n  Cada servicio expuesto = una superficie de ataque\n  Cada empleado con email público = un vector de phishing",
      "autoResize": true,
      "lineHeight": 1.25
    },
