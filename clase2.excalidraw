    {
      "id": "hSfQlmh0Ewi04-103-MYZ",
      "type": "text",
      "x": 2396.6476789604494,
      "y": 159.8028791599578,
      "width": 923.9987182617188,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fcc2d7",
      "fillStyle": "solid",
