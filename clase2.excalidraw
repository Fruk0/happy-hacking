      "seed": 2037681772,
      "version": 885,
      "versionNonce": 671132396,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776875649445,
      "link": null,
      "locked": false,
      "text": "200/204 = activo\n301/302 = interesante, seguir redirect\n401/403 = existe y está protegido\n404 = probablemente no existe\n429 = te están limitando\n5xx = existe algo atrás, pero está fallando",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "vD5i1AquCD9cfU1BGMQgn",
      "originalText": "200/204 = activo\n301/302 = interesante, seguir redirect\n401/403 = existe y está protegido\n404 = probablemente no existe\n429 = te están limitando\n5xx = existe algo atrás, pero está fallando",
      "autoResize": true,
      "lineHeight": 1.25
    },
