    },
    {
      "id": "fEFtArVOyoa7cL6MrevpE",
      "type": "text",
      "x": 2377.189455047247,
      "y": 975.3127901923451,
      "width": 527.999267578125,
      "height": 860,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fcc2d7",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0O",
      "roundness": null,
      "seed": 105039444,
      "version": 1753,
      "versionNonce": 1740429908,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776905867385,
      "link": null,
      "locked": false,
      "text": "GOOGLE DORKS\n\n- SUBDOMINIOS\nsite:*.tesla.com -www\n\n# site: = solo resultados de este dominio\n# *.  = wildcard — cualquier subdominio\n# -www = excluir www (lo conocemos, no es interesante)\n# Resultado: Google nos muestra subdominios que indexó\n\n- ARCHIVOS EXPUESTOS\nsite:tesla.com filetype:pdf\n\n# filetype: = solo este tipo de archivo\n# PDFs públicos de Tesla — investor relations, manuales,\n# documentos internos que alguien subió sin querer\n\n- Sitios de Login\nsite:tesla.com inurl:login\nsite:tesla.com inurl:admin\n\n# inurl: = la URL contiene esta cadena\n# Nos muestra páginas de autenticación indexadas por Google\n\n- Directorios abiertos\nintitle:\"index of\" site:tesla.com\n\n# intitle: = el título de la página contiene esto\n# \"index of\" = título por defecto de Apache directory\nlisting\n# Si aparece algo: un servidor con directory listing\nhabilitado\n# = acceso directo a archivos sin autenticación\n\n- Archivos sensibles\nsite:tesla.com ext:env OR ext:log OR ext:bak\n\n# ext: = extensión de archivo\n# .env = archivos de configuración con variables de entorno\na veces contienen credenciales, API keys, DB passwords\n# .log = logs de aplicación — pueden revelar stack, errores,\nusuarios\n# .bak = backups — a veces son copias del código fuente",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "f76Bdi3phw8VaNTGWiip6",
      "originalText": "GOOGLE DORKS\n\n- SUBDOMINIOS\nsite:*.tesla.com -www\n\n# site: = solo resultados de este dominio\n# *.  = wildcard — cualquier subdominio\n# -www = excluir www (lo conocemos, no es interesante)\n# Resultado: Google nos muestra subdominios que indexó\n\n- ARCHIVOS EXPUESTOS\nsite:tesla.com filetype:pdf\n\n# filetype: = solo este tipo de archivo\n# PDFs públicos de Tesla — investor relations, manuales,\n# documentos internos que alguien subió sin querer\n\n- Sitios de Login\nsite:tesla.com inurl:login\nsite:tesla.com inurl:admin\n\n# inurl: = la URL contiene esta cadena\n# Nos muestra páginas de autenticación indexadas por Google\n\n- Directorios abiertos\nintitle:\"index of\" site:tesla.com\n\n# intitle: = el título de la página contiene esto\n# \"index of\" = título por defecto de Apache directory listing\n# Si aparece algo: un servidor con directory listing habilitado\n# = acceso directo a archivos sin autenticación\n\n- Archivos sensibles\nsite:tesla.com ext:env OR ext:log OR ext:bak\n\n# ext: = extensión de archivo\n# .env = archivos de configuración con variables de entorno\na veces contienen credenciales, API keys, DB passwords\n# .log = logs de aplicación — pueden revelar stack, errores, usuarios\n# .bak = backups — a veces son copias del código fuente",
      "autoResize": true,
      "lineHeight": 1.25
    },
