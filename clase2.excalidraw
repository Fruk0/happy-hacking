    {
      "id": "Kyl2UNlgF7Qxpfj8RSBZE",
      "type": "text",
      "x": 563.326659073789,
      "y": 394.61831284222376,
      "width": 246.399658203125,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
