    {
      "id": "oY7rT58GjQjdLYSXfUiD0",
      "type": "text",
      "x": 161.06182579834012,
      "y": 214.7443674910586,
      "width": 582.4779020769075,
      "height": 104.03480866733867,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ap",
      "roundness": null,
      "seed": 1572038461,
      "version": 504,
      "versionNonce": 1475450580,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776882635845,
      "link": null,
      "locked": false,
      "text": "A         | Dominio → IPv4                  | Dónde vive el servidor\nMX        | Servidores de correo            | Infraestructura de mail\nNS        | Nameservers autoritativos       | Para zone transfer después\nTXT       | Texto libre                     | SPF, DKIM, verificaciones\nCNAME     | Alias de otro dominio           | Servicios cloud, subdominos",
      "fontSize": 16.645569386774188,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A         | Dominio → IPv4                  | Dónde vive el servidor\nMX        | Servidores de correo            | Infraestructura de mail\nNS        | Nameservers autoritativos       | Para zone transfer después\nTXT       | Texto libre                     | SPF, DKIM, verificaciones\nCNAME     | Alias de otro dominio           | Servicios cloud, subdominos",
      "autoResize": true,
      "lineHeight": 1.25
    },
