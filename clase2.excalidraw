    {
      "id": "EAPnbfgf0JJSbd_3m1PSU",
      "type": "text",
      "x": 1541.8429321116237,
      "y": -155.9755799892058,
      "width": 703.9990234375,
      "height": 800,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fcc2d7",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b01G",
      "roundness": null,
      "seed": 1528574444,
      "version": 645,
      "versionNonce": 1285121748,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776902440572,
      "link": null,
      "locked": false,
      "text": "    1. ENUMERAR SUBDOMINIOS\n\nsubfinder -d tesla.com | tee subs_tesla.txt\n\n# -d = dominio objetivo\n# -silent = sin banner ni logs — solo resultados\n# Fuentes que consulta: certificados SSL, DNS pasivo,\n# APIs públicas como VirusTotal, SecurityTrails, Shodan\n# Todo pasivo — no tocamos Tesla\n\n------------------------------\n     2. FILTRAR SUBDOMINIOS INTERESANTES\n\n\ncat subs_tesla.txt | grep -E \"api|admin|dev|staging|vpn|mail|internal|test|beta\"\n\n# grep -E = extended regex — buscar patrones\n# Esto filtra los subdominios que más nos interesan como atacantes\n\n------------------------------\n     3. FILTRAR SUBDOMINIOS QUE RESPONDAN\n\ncat subs_tesla.txt | dnsx -a -resp -silent\n\n# dnsx toma la lista de subdominios y resuelve cada uno\n# -a = solo registros A (IPv4)\n# -resp = mostrar la respuesta completa (IP)\n# -silent = sin banner\n# Resultado: subdominio → IP\n\n------------------------------\n     4. ¿EXISTE UN SERVICIO WEB QUE RESPONDA?\n\nReconocimiento de tecnologías y headers\n\ncat subs_tesla.txt | httpx -sc -location -ip -title -tech-detect\n\n------------------------------\n     4. REVISIÓN MANUAL\n",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "1vUuv-yTmlHuR_ztjj9vH",
      "originalText": "    1. ENUMERAR SUBDOMINIOS\n\nsubfinder -d tesla.com | tee subs_tesla.txt\n\n# -d = dominio objetivo\n# -silent = sin banner ni logs — solo resultados\n# Fuentes que consulta: certificados SSL, DNS pasivo,\n# APIs públicas como VirusTotal, SecurityTrails, Shodan\n# Todo pasivo — no tocamos Tesla\n\n------------------------------\n     2. FILTRAR SUBDOMINIOS INTERESANTES\n\n\ncat subs_tesla.txt | grep -E \"api|admin|dev|staging|vpn|mail|internal|test|beta\"\n\n# grep -E = extended regex — buscar patrones\n# Esto filtra los subdominios que más nos interesan como atacantes\n\n------------------------------\n     3. FILTRAR SUBDOMINIOS QUE RESPONDAN\n\ncat subs_tesla.txt | dnsx -a -resp -silent\n\n# dnsx toma la lista de subdominios y resuelve cada uno\n# -a = solo registros A (IPv4)\n# -resp = mostrar la respuesta completa (IP)\n# -silent = sin banner\n# Resultado: subdominio → IP\n\n------------------------------\n     4. ¿EXISTE UN SERVICIO WEB QUE RESPONDA?\n\nReconocimiento de tecnologías y headers\n\ncat subs_tesla.txt | httpx -sc -location -ip -title -tech-detect\n\n------------------------------\n     4. REVISIÓN MANUAL\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
